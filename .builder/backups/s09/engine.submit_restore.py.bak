from datetime import datetime

from builder.review.storage import storage


class ReviewEngine:

    def list(self):

        return storage.load()

    def approve(
        self,
        task_id: str,
        reviewer: str = "builder",
    ):

        tasks = storage.load()

        for task in tasks:

            if task.id == task_id:

                task.status = "approved"
                task.reviewer = reviewer
                task.reviewed_at = datetime.utcnow().isoformat()

                storage.save(tasks)

                return task

        return None

    def reject(
        self,
        task_id: str,
        reviewer: str = "builder",
    ):

        tasks = storage.load()

        for task in tasks:

            if task.id == task_id:

                task.status = "rejected"
                task.reviewer = reviewer
                task.reviewed_at = datetime.utcnow().isoformat()

                storage.save(tasks)

                return task

        return None


engine = ReviewEngine()
