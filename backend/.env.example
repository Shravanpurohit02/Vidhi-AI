# ==========================
# Vidhi AI Configuration
# ==========================

# Application
APP_NAME=Vidhi AI
APP_VERSION=0.1.0-alpha.1
APP_ENV=development
DEBUG=True

HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./vidhi_ai.db

# Logging
LOG_LEVEL=INFO

# ==========================
# AI Providers
# ==========================

# Default provider
DEFAULT_LLM_PROVIDER=mock

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=

# OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3
