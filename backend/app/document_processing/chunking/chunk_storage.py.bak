from __future__ import annotations

from pathlib import Path
import json


class ChunkStorage:
    """Simple JSON storage for document chunks."""

    def __init__(self, directory: str = "storage/chunks"):
        self.directory = Path(directory)
        self.directory.mkdir(parents=True, exist_ok=True)

    def save(self, document_id: str, chunks: list[dict]) -> Path:
        destination = self.directory / f"{document_id}.json"

        with destination.open("w", encoding="utf-8") as fp:
            json.dump(chunks, fp, indent=2, ensure_ascii=False)

        return destination

    def load(self, document_id: str) -> list[dict]:
        source = self.directory / f"{document_id}.json"

        if not source.exists():
            return []

        with source.open("r", encoding="utf-8") as fp:
            return json.load(fp)
